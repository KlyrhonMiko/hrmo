                         <div className=\"h-px bg-stone-100 my-2\" />\n\n                            <div>\n                                <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                    Training Title\n                                </label>\n                                <input\n                                    required\n                                    value={form.title}\n                                    onChange={(e) =>\n                                        setForm({ ...form, title: e.target.value })\n                                    }\n                                    readOnly={selectedEventId !== \"manual\"}\n                                    className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors ${\n                                        selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                    }`}\n                                    placeholder=\"e.g. Leadership Development Program\"\n                                />\n                            </div>\n\n                            <div className=\"grid grid-cols-2 gap-4\">\n                                <div>\n                                    <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                        Type\n                                    </label>\n                                    <select\n                                        value={form.training_type}\n                                        onChange={(e) =>\n                                            setForm({\n                                                ...form,\n                                                training_type: e.target\n                                                    .value as (typeof TRAINING_TYPES)[number],\n                                            })\n                                        }\n                                        disabled={selectedEventId !== \"manual\"}\n                                        className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors bg-white ${\n                                            selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                        }`}\n                                    >\n                                        {TRAINING_TYPES.map((t) => (\n                                            <option key={t} value={t}>\n                                                {t}\n                                            </option>\n                                        ))}\n                                    </select>\n                                </div>\n                                <div>\n                                    <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                        Provider\n                                    </label>\n                                    <input\n                                        required\n                                        value={form.provider}\n                                        onChange={(e) =>\n                                            setForm({ ...form, provider: e.target.value })\n                                        }\n                                        readOnly={selectedEventId !== \"manual\"}\n                                        className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors ${\n                                            selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                        }`}\n                                        placeholder=\"Training provider\"\n                                    />\n                                </div>\n                            </div>\n\n                            <div>\n                                <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                    Venue\n                                </label>\n                                <input\n                                    required\n                                    value={form.venue}\n                                    onChange={(e) =>\n                                        setForm({ ...form, venue: e.target.value })\n                                    }\n                                    readOnly={selectedEventId !== \"manual\"}\n                                    className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors ${\n                                        selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                    }`}\n                                    placeholder=\"Training venue or Online\"\n                                />\n                            </div>\n\n                            <div className=\"grid grid-cols-2 gap-4\">\n                                <div>\n                                    <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                        Date From\n                                    </label>\n                                    <input\n                                        required\n                                        type=\"date\"\n                                        value={form.date_from}\n                                        onChange={(e) =>\n                                            setForm({ ...form, date_from: e.target.value })\n                                        }\n                                        readOnly={selectedEventId !== \"manual\"}\n                                        className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors ${\n                                            selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                        }`}\n                                    />\n                                </div>\n                                <div>\n                                    <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                        Date To\n                                    </label>\n                                    <input\n                                        required\n                                        type=\"date\"\n                                        value={form.date_to}\n                                        onChange={(e) =>\n                                            setForm({ ...form, date_to: e.target.value })\n                                        }\n                                        readOnly={selectedEventId !== \"manual\"}\n                                        className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors ${\n                                            selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                        }`}\n                                    />\n                                </div>\n                            </div>\n\n                            <div className=\"grid grid-cols-2 gap-4\">\n                                <div>\n                                    <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                        Estimated Cost\n                                    </label>\n                                    <input\n                                        type=\"number\"\n                                        value={form.estimated_cost}\n                                        onChange={(e) =>\n                                            setForm({ ...form, estimated_cost: e.target.value })\n                                        }\n                                        className=\"w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors\"\n                                        placeholder=\"0.00\"\n                                    />\n                                </div>\n                                <div>\n                                    <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                        Training Hours\n                                    </label>\n                                    <input\n                                        required\n                                        type=\"number\"\n                                        value={form.number_of_hours}\n                                        onChange={(e) =>\n                                            setForm({\n                                                ...form,\n                                                number_of_hours: parseInt(e.target.value) || 0,\n                                            })\n                                        }\n                                        readOnly={selectedEventId !== \"manual\"}\n                                        className={`w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors ${\n                                            selectedEventId !== \"manual\" ? \"bg-stone-50 text-stone-500\" : \"\"\n                                        }`}\n                                        placeholder=\"0\"\n                                    />\n                                </div>\n                            </div>\n\n                            <div>\n                                <label className=\"block text-[12px] font-medium text-stone-600 mb-1.5\">\n                                    Justification\n                                </label>\n                                <textarea\n                                    required\n                                    rows={3}\n                                    value={form.justification}\n                                    onChange={(e) =>\n                                        setForm({ ...form, justification: e.target.value })\n                                    }\n                                    className=\"w-full px-3 py-2 text-[13px] border border-stone-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-green-600/20 focus:border-green-600 transition-colors resize-none\"\n                                    placeholder=\"Explain how this training will benefit your role and the organization...\"\n                                />\n                            </div>\n\n                            <div className=\"flex items-center justify-end gap-3 pt-2\">\n                                <button\n                                    type=\"button\"\n                                    onClick={() => setShowModal(false)}\n                                    className=\"px-4 py-2 text-[13px] font-medium text-stone-600 rounded-lg hover:bg-stone-100 transition-colors\"\n                                >\n                                    Cancel\n                                </button>\n                                <button\n                                    type=\"submit\"\n                                    className=\"inline-flex items-center gap-2 px-5 py-2 bg-green-700 text-white text-[13px] font-medium rounded-lg hover:bg-green-800 active:scale-[0.98] shadow-sm transition-all\"\n                                >\n                                    <Send className=\"w-3.5 h-3.5\" />\n                                    Submit Request\n                                </button>\n                            </div>\n                        </form>\n                    </div>\n                </div>\n            )}\n        </>\n    );\n}\n","usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/hr-record-asst/certificates/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/hr-record-asst/dashboard/page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'BudgetCard' is defined but never used.","line":4,"column":26,"nodeType":"Identifier","messageId":"unusedVar","endLine":4,"endColumn":36,"suggestions":[{"messageId":"removeUnusedVar","data":{"varName":"BudgetCard"},"fix":{"range":[65,77],"text":""},"desc":"Remove unused variable \"BudgetCard\"."}]}],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"\"use client\";\n\nimport React from \"react\";\nimport { DashboardStats, BudgetCard } from \"@/components/dashboard/DashboardStats\";\nimport { PersonnelCharts } from \"@/components/dashboard/PersonnelCharts\";\nimport { ComplianceSummary } from \"@/components/dashboard/ComplianceSummary\";\nimport { RecentActivity } from \"@/components/dashboard/RecentActivity\";\nimport { QuickActions } from \"@/components/dashboard/QuickActions\";\nimport Link from \"next/link\";\nimport {\n    UserPlus,\n    ScanLine,\n    FolderOpen,\n    GraduationCap,\n    ChevronRight,\n    FileWarning,\n    Clock,\n    CheckCircle,\n} from \"lucide-react\";\n\ntype TaskColor = \"amber\" | \"blue\" | \"green\";\n\nconst pendingTasks: Array<{ label: string; count: number; icon: React.ElementType; color: TaskColor }> = [\n    { label: \"PDS entries awaiting review\", count: 8, icon: FileWarning, color: \"amber\" },\n    { label: \"Certificates pending verification\", count: 14, icon: Clock, color: \"blue\" },\n    { label: \"201 files updated this week\", count: 23, icon: CheckCircle, color: \"green\" },\n];\n\nconst colorMap: Record<TaskColor, { bg: string; text: string }> = {\n    amber: { bg: \"bg-amber-50\", text: \"text-amber-700\" },\n    blue:  { bg: \"bg-blue-50\",  text: \"text-blue-700\"  },\n    green: { bg: \"bg-green-50\", text: \"text-green-700\" },\n};\n\ntype ShortcutColor = \"green\" | \"teal\" | \"emerald\" | \"amber\";\n\nconst shortcuts: Array<{ label: string; description: string; href: string; icon: React.ElementType; color: ShortcutColor }> = [\n    { label: \"PDS Data Entry\",   description: \"Add new employee record\",   href: \"/hr-record-asst/onboard\",           icon: UserPlus,    color: \"green\"   },\n    { label: \"Scan Certificates\", description: \"Upload MOV documents\",      href: \"/hr-record-asst/certificates\",      icon: ScanLine,    color: \"teal\"    },\n    { label: \"Employee 201\",     description: \"Browse employee files\",      href: \"/hr-record-asst/directory\",         icon: FolderOpen,  color: \"emerald\" },\n    { label: \"Training Records\", description: \"Track training data\",        href: \"/hr-record-asst/training/tracking\", icon: GraduationCap, color: \"amber\" },\n];\n\nconst shortcutColorMap: Record<ShortcutColor, { bg: string; text: string }> = {\n    green:   { bg: \"bg-green-50\",   text: \"text-green-700\"   },\n    teal:    { bg: \"bg-teal-50\",    text: \"text-teal-600\"    },\n    emerald: { bg: \"bg-emerald-50\", text: \"text-emerald-600\" },\n    amber:   { bg: \"bg-amber-50\",   text: \"text-amber-600\"   },\n};\n\nexport default function HRRecordAsstDashboard() {\n    return (\n        <div className=\"space-y-6 pb-8\">\n            <DashboardStats />\n\n            <div className=\"grid grid-cols-1 md:grid-cols-2 xl:grid-cols-4 gap-4\">\n                {shortcuts.map((item) => {\n                    const Icon = item.icon;\n                    const colors = shortcutColorMap[item.color];\n                    return (\n                        <Link\n                            key={item.href}\n                            href={item.href}\n                            className=\"group bg-white rounded-xl border border-stone-200/80 p-4 hover:shadow-sm transition-all duration-200 flex items-center gap-3\"\n                        >\n                            <div className={`w-10 h-10 rounded-lg ${colors.bg} ${colors.text} flex items-center justify-center shrink-0 group-hover:scale-105 transition-transform`}>\n                                <Icon className=\"w-5 h-5\" />\n                            </div>\n                            <div className=\"flex-1 min-w-0\">\n                                <p className=\"text-[13px] font-semibold text-stone-700 group-hover:text-stone-900 truncate\">{item.label}</p>\n                                <p className=\"text-[11px] text-stone-400 truncate\">{item.description}</p>\n                            </div>\n                            <ChevronRight className=\"w-4 h-4 text-stone-300 group-hover:text-stone-500 group-hover:translate-x-0.5 transition-all shrink-0\" />\n                        </Link>\n                    );\n                })}\n            </div>\n\n            <div className=\"grid grid-cols-1 xl:grid-cols-3 gap-6\">\n                <div className=\"xl:col-span-2\">\n                    <PersonnelCharts />\n                </div>\n           