 uploading\n        const secureUrl = `https://storage.plp.edu.ph/hrdo/movs/${crypto.randomUUID()}-${file.name}`;\n\n        // TODO: Insert doc record into DB mapping to employee\n\n        return NextResponse.json(\n            {\n                message: 'File uploaded successfully',\n                url: secureUrl,\n                documentType,\n                serialNumber\n            },\n            { status: 200 }\n        );\n    } catch (error: any) {\n        console.error('Error in /api/upload-mov:', error);\n        return NextResponse.json(\n            { error: 'Internal Server Error' },\n            { status: 500 }\n        );\n    }\n}\n","usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/auth/login/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/auth/register/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/employee/dashboard/page.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/employee/layout.tsx","messages":[],"suppressedMessages":[],"errorCount":0,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":[]},{"filePath":"/mnt/sdb4/Programming/Python/Web Projects/hrmo/frontend/src/app/employee/my-pds/page.tsx","messages":[{"ruleId":"@typescript-eslint/no-unused-vars","severity":1,"message":"'Edit3' is defined but never used.","line":7,"column":5,"nodeType":"Ident